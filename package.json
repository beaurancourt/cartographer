{
  "name": "cartographer-root",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace root: delegates frontend tasks to ui/, runs Tauri CLI from here so it can find crates/cartographer-tauri/tauri.conf.json.",
  "scripts": {
    "dev": "npm --prefix ui run dev",
    "build": "npm --prefix ui run build",
    "tauri": "cd crates/cartographer-tauri && tauri",
    "tauri:dev": "cd crates/cartographer-tauri && tauri dev",
    "tauri:build": "cd crates/cartographer-tauri && tauri build",
    "tauri:info": "cd crates/cartographer-tauri && tauri info"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
