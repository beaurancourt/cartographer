{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "Background": {
      "properties": {
        "style": {
          "allOf": [
            {
              "$ref": "#/definitions/BackgroundStyle"
            }
          ],
          "default": "ink"
        }
      },
      "type": "object"
    },
    "BackgroundStyle": {
      "oneOf": [
        {
          "description": "High-contrast black/white VTT style (Arden Vul, Old School Essentials, etc.). Black \"void\" with white floor; walls implicit from contrast.",
          "enum": [
            "ink"
          ],
          "type": "string"
        },
        {
          "description": "Warm cream parchment with hatched floor.",
          "enum": [
            "parchment"
          ],
          "type": "string"
        },
        {
          "description": "Plain white floor on white background with thin grey grid.",
          "enum": [
            "clean"
          ],
          "type": "string"
        },
        {
          "description": "Inverted \"blueprint\" style — white linework on dark blue.",
          "enum": [
            "blueprint"
          ],
          "type": "string"
        }
      ]
    },
    "Carve": {
      "anyOf": [
        {
          "allOf": [
            {
              "$ref": "#/definitions/RectCarve"
            }
          ],
          "description": "Rectangular carve-out (room)."
        },
        {
          "allOf": [
            {
              "$ref": "#/definitions/PathCarve"
            }
          ],
          "description": "Axis-aligned strip along a polyline."
        }
      ],
      "description": "A single carve-out. The two variants are distinguished by their fields: presence of `rect` → rectangular room; presence of `path` → strip."
    },
    "CellCoord": {
      "description": "Coordinate in whole-cell units. Sub-cell positions are rounded to the nearest 1/12 cell on read (so halves, thirds, quarters, sixths, and twelfths are exact).",
      "type": "number"
    },
    "Facing": {
      "oneOf": [
        {
          "enum": [
            "n",
            "s",
            "e",
            "w"
          ],
          "type": "string"
        },
        {
          "description": "North-south passage — door panel perpendicular to the N-S axis, i.e. door sits in a horizontal (east-west) wall.",
          "enum": [
            "ns"
          ],
          "type": "string"
        },
        {
          "description": "East-west passage — door panel perpendicular to the E-W axis, i.e. door sits in a vertical (north-south) wall.",
          "enum": [
            "ew"
          ],
          "type": "string"
        }
      ]
    },
    "FloorStyle": {
      "enum": [
        "hatched",
        "solid",
        "dotted"
      ],
      "type": "string"
    },
    "Grid": {
      "properties": {
        "cell_size": {
          "description": "Pixels per cell at 1.0 zoom. Default 50.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "ft_per_cell": {
          "description": "Informational only — how many real-world units one cell represents.",
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "units": {
          "description": "Informational only (e.g. \"ft\", \"m\").",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "cell_size"
      ],
      "type": "object"
    },
    "Layer": {
      "properties": {
        "carves": {
          "default": [],
          "description": "Carve-outs that make up the floor. Each carve is either a `rect` (rectangular room) or a `path` + `width` (axis-aligned strip). The final floor is the union of every carve in the layer.",
          "items": {
            "$ref": "#/definitions/Carve"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "objects": {
          "default": [],
          "items": {
            "$ref": "#/definitions/MapObject"
          },
          "type": "array"
        },
        "style": {
          "allOf": [
            {
              "$ref": "#/definitions/LayerStyle"
            }
          ],
          "default": {
            "floor": "hatched",
            "wall": "solid"
          }
        }
      },
      "required": [
        "id"
      ],
      "type": "object"
    },
    "LayerStyle": {
      "properties": {
        "floor": {
          "allOf": [
            {
              "$ref": "#/definitions/FloorStyle"
            }
          ],
          "default": "hatched"
        },
        "wall": {
          "allOf": [
            {
              "$ref": "#/definitions/WallStyle"
            }
          ],
          "default": "solid"
        }
      },
      "type": "object"
    },
    "MapObject": {
      "description": "A placed symbol/object — door, trap, stairs, altar, etc. The `kind` references a symbol registered in [`crate::symbols`].",
      "properties": {
        "at": {
          "description": "Cell coordinate of the cell the object occupies (its symbol is drawn centered in this cell).",
          "items": {
            "$ref": "#/definitions/CellCoord"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        "facing": {
          "anyOf": [
            {
              "$ref": "#/definitions/Facing"
            },
            {
              "type": "null"
            }
          ],
          "description": "Orientation. Doors typically use `ew`/`ns`; stairs use `n`/`s`/`e`/`w`."
        },
        "id": {
          "type": "string"
        },
        "type": {
          "description": "Symbol id, e.g. `door`, `secret-door`, `pit-trap`, `stairs-down`.",
          "type": "string"
        }
      },
      "required": [
        "at",
        "id",
        "type"
      ],
      "type": "object"
    },
    "Note": {
      "properties": {
        "at": {
          "items": {
            "$ref": "#/definitions/CellCoord"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "at",
        "text"
      ],
      "type": "object"
    },
    "PathCarve": {
      "properties": {
        "id": {
          "type": "string"
        },
        "path": {
          "description": "Sequence of cell-coordinate waypoints. Segments must be axis-aligned.",
          "items": {
            "items": {
              "$ref": "#/definitions/CellCoord"
            },
            "maxItems": 2,
            "minItems": 2,
            "type": "array"
          },
          "type": "array"
        },
        "width": {
          "allOf": [
            {
              "$ref": "#/definitions/CellCoord"
            }
          ],
          "default": 1,
          "description": "Width in cell units. Defaults to 1 cell."
        }
      },
      "required": [
        "id",
        "path"
      ],
      "type": "object"
    },
    "RectCarve": {
      "properties": {
        "id": {
          "type": "string"
        },
        "rect": {
          "description": "`[x, y, width, height]` in cell units. `w`/`h` must be positive.",
          "items": {
            "$ref": "#/definitions/CellCoord"
          },
          "maxItems": 4,
          "minItems": 4,
          "type": "array"
        }
      },
      "required": [
        "id",
        "rect"
      ],
      "type": "object"
    },
    "WallStyle": {
      "enum": [
        "solid"
      ],
      "type": "string"
    }
  },
  "description": "A complete cartographer map.",
  "properties": {
    "background": {
      "allOf": [
        {
          "$ref": "#/definitions/Background"
        }
      ],
      "default": {
        "style": "ink"
      }
    },
    "grid": {
      "allOf": [
        {
          "$ref": "#/definitions/Grid"
        }
      ],
      "default": {
        "cell_size": 50,
        "ft_per_cell": 5,
        "units": "ft"
      }
    },
    "layers": {
      "items": {
        "$ref": "#/definitions/Layer"
      },
      "type": "array"
    },
    "notes": {
      "default": [],
      "items": {
        "$ref": "#/definitions/Note"
      },
      "type": "array"
    },
    "version": {
      "description": "Format version. Currently always 1.",
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    }
  },
  "required": [
    "layers",
    "version"
  ],
  "title": "Map",
  "type": "object"
}